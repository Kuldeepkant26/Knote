NODE_ENV=development
PORT=5001

# MongoDB
MONGO_URL=mongodb+srv://<user>:<password>@<cluster-url>/Knote

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Password reset token expiry (minutes)
RESET_TOKEN_EXPIRES_MIN=15

# Signup OTP expiry (minutes)
OTP_EXPIRES_MIN=10

# Frontend URL (used to build reset-password links)
CLIENT_URL=http://localhost:5173

# Brevo (transactional email API) - https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
EMAIL_FROM=your_sender@example.com
EMAIL_FROM_NAME=Knote

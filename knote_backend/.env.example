NODE_ENV=development
PORT=5001

# MongoDB
MONGO_URL=mongodb+srv://<user>:<password>@<cluster-url>/Knote

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Password reset token expiry (minutes)
RESET_TOKEN_EXPIRES_MIN=15

# Frontend URL (used to build reset-password links)
CLIENT_URL=http://localhost:5173

# Gmail SMTP (Nodemailer) - use a Gmail App Password, not your real password
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Knote <your_gmail_address@gmail.com>"
